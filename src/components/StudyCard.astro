---
const { imagen, nombre, institucion, año, descripcion } = Astro.props;
---


<div class="flex flex-col md:flex-row items-center justify-between w-full py-8 px-4">
  <div class="flex-shrink-0 mb-6 md:mb-0 md:mr-8">
    <div class="w-40 h-40 flex items-center justify-center overflow-hidden">
      {imagen ? (
        <img src={imagen} alt={nombre} class="object-contain w-full h-full" />
      ) : (
        <img src="/images/logo-uniminuto.webp" alt="Logo Uniminuto" class="object-contain w-full h-full" />
      )}
    </div>
  </div>
  <div class="flex-1 flex flex-col gap-2 w-full">
    <div class="text-2xl text-surface">{nombre || "Nombre del estudio"}</div>
    <div class="text-base text-surface opacity-80">{institucion || "Institución"} - {año || "Año"}</div>
    <div class="text-base text-surface opacity-70">{descripcion || "Descripción del estudio o certificado."}</div>
  </div>
</div>
