---
const { imagen, nombre, institucion, año, descripcion } = Astro.props;
---
<div class="bg-[var(--gloss)] border border-zinc-200 shadow-md p-6 flex flex-col gap-4">
  <div class="w-full aspect-square bg-zinc-100 flex items-center justify-center mb-4">
    <img src={imagen} alt={nombre} class="object-contain h-5/6 w-5/6" />
  </div>
  <div class="text-lg font-semibold text-surface mb-2">{nombre}</div>
  <div class="text-base text-surface opacity-80 mb-1">{institucion} - {año}</div>
  <div class="text-base text-surface opacity-70">{descripcion}</div>
</div>
