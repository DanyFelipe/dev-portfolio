---
// components/NotebookCard.astro
const { tech } = Astro.props;
---

<a href={tech.url} target="_blank" class="group relative block rounded-2xl border border-cyan-500/20 bg-black/60 p-4 backdrop-blur-md shadow-md hover:border-cyan-400 hover:shadow-cyan-500/30 transition duration-300">
  <div class="flex gap-4">
    <img src={tech.image} alt={tech.name} class="w-16 h-16 object-contain rounded-lg border border-cyan-500/30" />
    <div class="flex-1">
      <h3 class="text-cyan-400 text-lg font-bold font-orbitron group-hover:text-cyan-300 transition">
        {tech.name}
      </h3>
      <p class="text-sm text-white/80">{tech.description}</p>
      <div class="flex flex-wrap gap-1 mt-2">
        {tech.categories.map((cat: string) => (
            <span class="...">{cat}</span>
          ))}
      </div>
    </div>
  </div>

  <!-- HUD scanlines overlay -->
  <div class="pointer-events-none absolute inset-0 bg-[url('/hud/scanlines.png')] mix-blend-screen opacity-10"></div>
</a>
