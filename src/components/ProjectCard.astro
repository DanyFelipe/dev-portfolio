---
const { title, tag, description, image, hoverGif, href } = Astro.props;
import Button from "@/components/Button.astro";
---
<div class="w-full bg-transparent rounded-none overflow-hidden shadow-none">
  <div class="flex flex-col md:flex-row">
    <!-- Columna derecha: imagen (en móvil va arriba) -->
    <div class="flex-1 flex items-center justify-center bg-zinc-800 aspect-square relative group/image">
      <img
        src={image}
        alt={title}
        class="object-cover w-full h-full transition-opacity duration-500 group-hover/image:opacity-0"
      />
      {hoverGif && (
        <img
          src={hoverGif}
          alt={title + ' gif'}
          class="object-cover w-full h-full absolute inset-0 transition-opacity duration-500 opacity-0 group-hover/image:opacity-100"
        />
      )}
    </div>
    <!-- Columna izquierda: info -->
    <div class="flex-1 flex flex-col justify-start px-2 py-3 md:py-4 md:px-4 space-y-2 mt-0">
      <h2 class="text-5xl md:text-7xl font-normal text-white">{title}</h2>
      <div class="h-px bg-zinc-700"></div>
      <div class="text-base md:text-xl text-white">{tag}</div>
      <div class="h-px bg-zinc-700"></div>
      <p class="text-zinc-300 text-base md:text-xl mt-auto">{description}</p>
    </div>
  </div>
  <Button href={href} target="_blank" rel="noopener noreferrer" class="w-full block mt-4">VER PROYECTO</Button>
</div> 