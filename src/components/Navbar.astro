---
import MobileNavbar from './MobileNavbar.jsx';
---

<!-- Desktop navbar -->
<nav class="hidden md:flex fixed top-6 left-1/2 -translate-x-1/2 z-50 flex-col items-center justify-center py-0"
  style="background: var(--glass-bg); border: var(--glass-border); backdrop-filter: var(--glass-blur);">
  <ul class="flex justify-center">
    <li>
      <a href="/" class="inline-block hover:bg-white hover:text-black text-[var(--color-surface)] transition-colors duration-150 py-2 px-6 text-base md:text-base tracking-wide">PRINCIPAL</a>
    </li>
    <li>
      <a href="/projects" class="inline-block hover:bg-white hover:text-black text-[var(--color-surface)] transition-colors duration-150 py-2 px-6 text-base md:text-base tracking-wide">PROYECTOS</a>
    </li>
    <li>
      <a href="/experience" class="inline-block hover:bg-white hover:text-black text-[var(--color-surface)] transition-colors duration-150 py-2 px-6 text-base md:text-base tracking-wide">EXPERIENCIA</a>
    </li>
    <li>
      <a href="/studies" class="inline-block hover:bg-white hover:text-black text-[var(--color-surface)] transition-colors duration-150 py-2 px-6 text-base md:text-base tracking-wide">ESTUDIOS</a>
    </li>
  </ul>
</nav>

<MobileNavbar client:only="react" />
