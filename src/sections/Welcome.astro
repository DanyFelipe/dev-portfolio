---
import Button from "@/components/Button.astro";
import LineDivisor from "@/components/LineDivisor.astro";
import TypewriterEffect from "@/components/TypewriterEffect.jsx";
import IconCarousel from "@/components/IconCarousel.jsx";
---

<div class="mx-auto max-w-7xl px-12 flex flex-col min-h-screen">
  <div class="flex-1 flex flex-col items-center text-center md:items-start md:text-left justify-center mt-20">
    <div class="text-5xl md:text-6xl font-extrabold text-white mb-2">
      <div>HI, I'M DANIEL FELIPE</div>
      <div class="min-h-[3rem] sm:min-h-0">
        <!-- Reserva espacio en móviles -->
        AND I AM
      </div>
    </div>
    <div
      class="text-3xl sm:text-3xl md:text-5xl lg:text-6xl font-extrabold text-white mb-2 min-h-[3.5rem]"
    >
      <TypewriterEffect
        client:only="react"
        texts={[
          "FRONTEND DEVELOPER",
          "BACKEND DEVELOPER",
          "VIDEOGAMES DEVELOPER",
        ]}
        delay={40}
        className="inline-block text-white"
      />
    </div>
    <div
      class="text-lg md:text-2xl text-zinc-700 dark:text-zinc-200 font-medium mb-6 mt-4"
    >
      Welcome to my developer portfolio
    </div>
    <div>
      <Button href="/files/CV - Daniel Felipe Pérez.pdf" download>
        _DOWNLOAD CV
      </Button>
    </div>
    <div class="flex flex-row items-center mt-6">
      <div class="flex flex-col sm:flex-row gap-0 w-full">
        <a
          href="https://github.com/DanyFelipe"
          target="_blank"
          rel="noopener"
          class="flex-1 text-center inline-block hover:bg-white hover:text-black transition-colors duration-150 py-2 px-6 text-base tracking-wide text-white"
        >
          _GITHUB
        </a>
        <a
          href="https://www.linkedin.com/in/daniel-felipe-4010b3232"
          target="_blank"
          rel="noopener"
          class="flex-1 text-center inline-block hover:bg-white hover:text-black transition-colors duration-150 py-2 px-6 text-base tracking-wide text-white"
        >
          _LINKEDIN
        </a>
        <a
          href="https://www.instagram.com/danylfelipe/"
          target="_blank"
          rel="noopener"
          class="flex-1 text-center inline-block hover:bg-white hover:text-black transition-colors duration-150 py-2 px-6 text-base tracking-wide text-white"
        >
          _INSTAGRAM
        </a>
        <a
          href="https://instagram.com/tu_usuario"
          target="_blank"
          rel="noopener"
          class="flex-1 text-center inline-block hover:bg-white hover:text-black transition-colors duration-150 py-2 px-6 text-base tracking-wide text-white"
        >
          _MAIL
        </a>
      </div>
    </div>
  </div>

  <div class="pb-10 text-white w-full mt-0 mb-0">
    <div class="text-center text-white mb-1">
      <div class="text-lg md:text-xl font-medium">My devtools</div>
      <div class="w-full flex justify-center">
        <IconCarousel client:only="react" />
      </div>
    </div>
    <LineDivisor class="mt-4" />
  </div>
</div>
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
