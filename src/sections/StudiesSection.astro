---
import StudyCard from "@/components/StudyCard.astro";
import studies from "@/data/studies.json";
---
<section class="w-full py-16 px-4 flex justify-center">
  <div class="w-full max-w-4xl">
  <header class="mb-12">
  </header>
  <main>
    <div class="flex flex-col gap-0 w-full">
      {studies.map((studyProps) => (
        <StudyCard {...studyProps} />
      ))}
    </div>
  </main>
  <footer class="mt-16 text-center text-base text-surface opacity-60">
    Última actualización: Julio 2025
  </footer>
</section>

